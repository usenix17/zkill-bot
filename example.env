# Environment
NODE_ENV=development
LOG_LEVEL=info

# Enrichment
EVE_DB_PATH=./eve.db

# Observability
OBS_METRICS_LOG_INTERVAL_MS=60000
OBS_REPEATED_403_THRESHOLD=3
OBS_REPEATED_429_THRESHOLD=5
OBS_STALLED_SEQUENCE_MS=900000
OBS_DEAD_LETTER_PENDING_THRESHOLD=25
OBS_ALERT_WEBHOOK_URL=""

# R2Z2 endpoints
R2Z2_BASE_URL=https://r2z2.zkillboard.com
R2Z2_SEQUENCE_PATH=/ephemeral/sequence.json

# Polling
POLL_INTERVAL_MS=100
POLL_404_BACKOFF_MS=6000

# Retries
RETRY_MAX_RETRIES=5
RETRY_BASE_BACKOFF_MS=250
RETRY_MAX_BACKOFF_MS=10000

# Rules
RULES_FILE_PATH=./config/rules.yaml
